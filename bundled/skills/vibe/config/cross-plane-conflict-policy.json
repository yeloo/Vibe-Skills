      "allowed_outputs": [
        "pattern_cards",
        "risk_checklist",
        "quality_metadata"
      ],
      "forbid_override": [
        "selected_pack",
        "selected_skill",
        "router_decision"
      ]
    },
    "browserops-provider": {
      "role": "provider_advice",
      "allowed_outputs": [
        "provider_recommendation",
        "confirm_required_hint",
        "fallback_hint"
      ],
      "forbid_override": [
        "route_selection",
        "execution_owner",
        "second_orchestrator"
      ]
    },
    "desktopops-shadow": {
      "role": "desktop_shadow_contract",
      "allowed_outputs": [
        "aci_contract",
        "openworld_checklist",
        "fallback_plan"
      ],
      "forbid_override": [
        "default_execution_owner",
        "route_selection",
        "second_orchestrator"
      ]
    }
  },
  "conflict_resolution": {
    "authority_overlap": {
      "action": "freeze_to_shadow",
      "winner": "higher_precedence_plane",
      "manual_review_required": true
    },
    "contract_contradiction": {
      "action": "prefer_higher_precedence_and_record_conflict",
      "manual_review_required": true
    },
    "confirmation_mismatch": {
      "action": "confirm_required_wins",
      "manual_review_required": false
    },
    "promotion_mismatch": {
      "action": "block_promotion_and_revert_to_candidate_state",
      "manual_review_required": true
    }
  },
  "rollout_guards": {
    "freeze_promotion_on_conflict": true,
    "fallback_stage": "shadow",
    "require_manual_review_for_cross_plane_conflict": true,
    "advice_first_only_when_conflict_exists": true
  }
}
