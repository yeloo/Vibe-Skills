{
  "version": 1,
  "updated_at": "2026-03-13",
  "policy": "router-model-neutrality",
  "control_plane_owner": "canonical-pack-router",
  "provider_layer": {
    "enabled": true,
    "authoritative": false,
    "replaceable": true,
    "provider_neutral_contract_required": true
  },
  "provider_neutral_contract": {
    "schema_path": "schemas/router-provider.schema.json",
    "provider_registry_path": "config/router-provider-registry.json",
    "provider_defaults_path": "config/router-provider-defaults.json",
    "provider_layer_doc_path": "docs/universalization/router-provider-layer.md",
    "verification_gates": [
      "scripts/verify/vibe-router-provider-neutrality-gate.ps1",
      "scripts/verify/vibe-router-offline-degrade-contract-gate.ps1"
    ],
    "runtime_boundary": {
      "canonical_authority_script": "scripts/router/resolve-pack-route.ps1",
      "do_not_modify_router_scripts_in_governance_phase": true,
      "no_second_router": true
    },
    "degrade_honesty": {
      "fallback_provider_mode": "heuristic-only",
      "offline_frozen_state": "offline-frozen",
      "silent_provider_absence_forbidden": true
