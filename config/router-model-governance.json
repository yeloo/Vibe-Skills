    "canonical_assignment_owner",
    "second_router",
    "live_router_takeover",
    "explicit_command_override",
    "release_chain_owner"
  ],
  "runtime_states": [
    "provider-assisted",
    "heuristic-only",
    "offline-frozen",
    "unsupported"
  ],
  "hard_rules": {
    "single_routing_authority": true,
    "no_second_router": true,
    "no_provider_lockin_claims": true,
    "must_label_degraded_state_explicitly": true,
    "must_support_truthful_no-provider_mode": true
  },
  "current_observed_bindings": [
    "scripts/router/modules/01-openai-responses.ps1",
    "config/settings.template.codex.json",
    "config/ruc-nlpir-runtime.json"
  ],
  "promotion_requirements": [
    "provider-neutral governance document exists",
    "provider-assisted versus heuristic-only boundary is explicit",
    "cross-host provider-state wording is truthful",
    "router contract remains single-authority"
  ]
}
