# Normalize governed text assets so canonical / bundled / nested parity stays deterministic.
* text=auto

*.md text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.sh text eol=lf
*.txt text eol=lf
*.svg text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
