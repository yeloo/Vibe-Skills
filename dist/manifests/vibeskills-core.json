{
  "manifest_kind": "vibeskills-distribution-manifest",
  "manifest_version": 1,
  "package_id": "vibeskills-core",
  "package_name": "VibeSkills Core Contracts",
  "status": "supported-with-constraints",
  "runtime_role": "contract-layer",
  "summary": "Host-agnostic contracts and schemas that stabilize skill metadata without claiming a governed runtime on any host.",
  "truth_sources": [
    "docs/universalization/core-contract.md",
    "docs/universalization/host-capability-matrix.md",
    "docs/universalization/platform-parity-contract.md",
    "docs/plans/2026-03-13-universal-vibeskills-execution-program.md"
  ],
  "delivers": {
    "contracts": [
      "core/skill-contracts/index.json",
      "core/skill-contracts/v1/*.json"
    ],
    "schemas": [
      "schemas/skill.schema.json",
      "schemas/skill-contract.v1.schema.json",
      "schemas/skill-contract-index.v1.schema.json",
      "schemas/host-capability.schema.json",
      "schemas/skill-compatibility.schema.json"
    ],
    "docs": [
      "docs/universalization/core-contract.md"
    ]
  },
  "host_managed_surfaces": [
    "all runtime install surfaces",
    "all host plugin provisioning",
    "all MCP registration and authorization",
    "all provider secret storage and availability"
  ],
  "degrade_states": {
    "missing_provider_or_mcp": "advisory-only",
    "host_without_required_exec_capabilities": "advisory-only"
  },
  "anti_overclaim": [
    "This package does not claim Codex/Claude Code/OpenCode parity.",
    "This package does not imply an install/check closure lane exists on any host."
  ]
}

