{
  "manifest_kind": "vibeskills-distribution-manifest",
  "manifest_version": 1,
  "package_id": "vibeskills-codex",
  "package_name": "VibeSkills for Codex (Supported With Constraints)",
  "status": "supported-with-constraints",
  "runtime_role": "official-runtime-adapter",
  "summary": "Codex is the current strongest practical reference lane for the governed runtime payload, but some key surfaces remain host-managed and certain platforms are degraded.",
  "truth_sources": [
    "docs/universalization/host-capability-matrix.md",
    "docs/universalization/platform-parity-contract.md",
    "adapters/codex/host-profile.json",
    "adapters/codex/platform-windows.json",
    "adapters/codex/platform-linux.json",
    "adapters/codex/platform-macos.json",
    "README.md"
  ],
  "host_adapter_ref": "adapters/codex/host-profile.json",
  "platform_contracts": [
    "adapters/codex/platform-windows.json",
    "adapters/codex/platform-linux.json",
    "adapters/codex/platform-macos.json"
  ],
  "install_entrypoints": {
    "windows_authoritative": [
      "install.ps1",
      "scripts/bootstrap/one-shot-setup.ps1",
      "check.ps1"
    ],
    "linux_supported_with_constraints": [
      "install.sh",
      "scripts/bootstrap/one-shot-setup.sh",
      "check.sh"
    ],
    "notes": [
      "This manifest does not change or replace install/check chains; it documents their support boundary.",
      "Linux without pwsh is a degraded state, not silently equivalent to Windows."
    ]
  },
  "host_managed_surfaces": [
    "plugin provisioning",
    "MCP provider credentials",
    "external CLI availability",
    "operator-specific secrets"
  ],
  "degrade_states": {
    "linux_without_pwsh": "degraded-but-supported",
    "missing_host_plugins": "degraded-but-supported",
    "missing_provider_credentials": "degraded-but-supported"
  },
  "anti_overclaim": [
    "Codex support does not imply Claude Code or Generic Host closure.",
    "Supported-with-constraints does not mean 'everything ready' if host provisioning is incomplete.",
    "macOS remains not-yet-proven in the platform parity contract."
  ]
}

